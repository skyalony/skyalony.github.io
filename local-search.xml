  <entry>
    <title>一元二次方程的python实现</title>
    <link href="/2021/10/31/%E4%BA%8C%E6%AC%A1%E6%96%B9%E7%A8%8B%E7%9A%84python/"/>
    <url>/2021/10/31/%E4%BA%8C%E6%AC%A1%E6%96%B9%E7%A8%8B%E7%9A%84python/</url>
    
    <content type="html"><![CDATA[<figure class="highlight python"><table><tr><td class="gutter hljs"><div class="hljs code-wrapper"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br></pre></div></td><td class="code"><div class="hljs code-wrapper"><pre><code class="hljs python"><span class="hljs-keyword">import</span> math<br>a = <span class="hljs-built_in">eval</span>(<span class="hljs-built_in">input</span>())<br>b = <span class="hljs-built_in">eval</span>(<span class="hljs-built_in">input</span>())<br>c = <span class="hljs-built_in">eval</span>(<span class="hljs-built_in">input</span>())<br><span class="hljs-keyword">if</span> a == <span class="hljs-number">0</span>:<br>    <span class="hljs-keyword">if</span> b == <span class="hljs-number">0</span>:<br>        <span class="hljs-built_in">print</span>(<span class="hljs-string">&#x27;Data error!&#x27;</span>)<br>    <span class="hljs-keyword">else</span>:<br>        <span class="hljs-built_in">print</span>(<span class="hljs-built_in">round</span>(c/(-b),<span class="hljs-number">2</span>))<br><span class="hljs-keyword">else</span>:<br>    <span class="hljs-keyword">if</span> b * b - <span class="hljs-number">4</span> * a * c &lt; <span class="hljs-number">0</span>:<br>        <span class="hljs-built_in">print</span>(<span class="hljs-string">&#x27;该方程无实数解&#x27;</span>)<br>    <span class="hljs-keyword">elif</span> b * b - <span class="hljs-number">4</span> * a * c == <span class="hljs-number">0</span>:<br>        <span class="hljs-built_in">print</span>(<span class="hljs-built_in">round</span>(-b/(<span class="hljs-number">2</span> * a),<span class="hljs-number">2</span>))<br>    <span class="hljs-keyword">else</span> :<br>        u = (-b+math.sqrt(b * b - <span class="hljs-number">4</span> * a * c)) / (<span class="hljs-number">2</span> * a)<br>        v = (-b-math.sqrt(b * b - <span class="hljs-number">4</span> * a * c)) / (<span class="hljs-number">2</span> * a) <br>        u_1 = <span class="hljs-built_in">round</span>(u,<span class="hljs-number">2</span>)<br>        v_1 = <span class="hljs-built_in">round</span>(v,<span class="hljs-number">2</span>)<br>        <span class="hljs-built_in">print</span>(u_1,v_1,sep=<span class="hljs-string">&#x27; &#x27;</span>)<br></code></pre></div></td></tr></table></figure><p>下方为答案</p><figure class="highlight python"><table><tr><td class="gutter hljs"><div class="hljs code-wrapper"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br></pre></div></td><td class="code"><div class="hljs code-wrapper"><pre><code class="hljs python">a = <span class="hljs-built_in">float</span>(<span class="hljs-built_in">input</span>())<br>b = <span class="hljs-built_in">float</span>(<span class="hljs-built_in">input</span>())<br>c = <span class="hljs-built_in">float</span>(<span class="hljs-built_in">input</span>())<br>delta = b * b - <span class="hljs-number">4</span> * a * c<br><span class="hljs-keyword">if</span> a == <span class="hljs-number">0</span> <span class="hljs-keyword">and</span> b != <span class="hljs-number">0</span>:<br>    <span class="hljs-comment">#print( round(- c / b,2))</span><br>    <span class="hljs-built_in">print</span>(<span class="hljs-string">&#x27;&#123;:.2f&#125;&#x27;</span>.<span class="hljs-built_in">format</span>(- c / b))<br><span class="hljs-keyword">elif</span> a == <span class="hljs-number">0</span> <span class="hljs-keyword">and</span> b == <span class="hljs-number">0</span>:<br>    <span class="hljs-built_in">print</span>(<span class="hljs-string">&#x27;Data error!&#x27;</span>)<br><span class="hljs-keyword">elif</span> delta &lt; <span class="hljs-number">0</span>:<br>    <span class="hljs-built_in">print</span>(<span class="hljs-string">&quot;该方程无实数解&quot;</span>)<br><span class="hljs-keyword">elif</span> delta == <span class="hljs-number">0</span>:<br>    <span class="hljs-comment">#print(round(-b  / (2 * a),2))</span><br>    <span class="hljs-built_in">print</span>(<span class="hljs-string">&#x27;&#123;:.2f&#125;&#x27;</span>.<span class="hljs-built_in">format</span>(-b  / (<span class="hljs-number">2</span> * a)))<br><span class="hljs-keyword">else</span>:<br>    x1 = (-b + delta ** <span class="hljs-number">0.5</span>) /( a * <span class="hljs-number">2</span>)<br>    x2 = (-b - delta ** <span class="hljs-number">0.5</span>) /(a * <span class="hljs-number">2</span>)<br>    <span class="hljs-keyword">if</span> x1 &lt; x2:<br>    x1,x2=x2,x1<br>    <span class="hljs-comment">#print(round(x1,2),round(x2,2))  # round()函数获得的浮点数会自动转为最短表示，例如rount(3.10000, 2) 的结果是3.1，而不是3.10</span><br>    <span class="hljs-built_in">print</span>(<span class="hljs-string">&#x27;&#123;:.2f&#125; &#123;:.2f&#125;&#x27;</span>.<span class="hljs-built_in">format</span>(x1,x2))    <span class="hljs-comment"># str.format()的方法可以严格按约定保留小数位数，例如&#x27;&#123;:.2f&#125;&#x27;.format(3.100000) 的结果是3.10</span><br></code></pre></div></td></tr></table></figure>]]></content>
    
    
